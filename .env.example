# Agent LLM provider keys — the active profile's llm.provider selects which one is required.
# Google AI Studio (Gemini) free-tier key (provider: "gemini"). https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Groq free-tier key (provider: "groq") — OpenAI-compatible, ~30 RPM / 1000 RPD. https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Absolute path to the local Solana keypair JSON file (gitignored), funded via testnet faucet.
# Generated by scripts/setup-keypair.sh (added in a later story).
KEYPAIR_PATH=/absolute/path/to/keypair.json

# SolInfra Ace gRPC endpoint — required for the mainnet-grpc profile.
# Format: host:port (no scheme). e.g. fra.grpc.solinfra.dev:443
SOLINFRA_GRPC_ENDPOINT=fra.grpc.solinfra.dev:443

# SolInfra gRPC auth token — raw key WITHOUT the grpc_ prefix (prefixed form returns "unauthorized").
SOLINFRA_GRPC_TOKEN=your-solinfra-grpc-token-here

# SolInfra RPC API key — separate from the gRPC token, used for the mainnet-grpc rpcEndpoint.
SOLINFRA_RPC_KEY=your-solinfra-rpc-key-here
